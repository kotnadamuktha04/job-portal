# ============================================================
# Supabase — get these from:
# Supabase Dashboard → Project Settings → API
# ============================================================

# Used by the Vercel serverless functions (api/index.js)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Used by the React frontend (must be prefixed with REACT_APP_)
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-public-key-here

# ============================================================
# HOW TO ADD THESE TO VERCEL:
# 1. Go to vercel.com → your project → Settings → Environment Variables
# 2. Add each variable above with its real value
# 3. Redeploy the project
# ============================================================
